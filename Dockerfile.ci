FROM swift:5.10.1-jammy

RUN apt-get update && apt-get install -y git clang-15 \
    && ln -sf /usr/bin/clang-15 /usr/bin/clang \
    && rm -rf /var/lib/apt/lists/*

COPY RockitCompiler /opt/rockit/RockitCompiler

RUN cd /opt/rockit/RockitCompiler \
    && swift run rockit build-native Stage1/command.rok

ENV ROCKIT_COMPILER=/opt/rockit/RockitCompiler/Stage1/command
ENV ROCKIT_RUNTIME=/opt/rockit/RockitCompiler/Runtime/rockit_runtime.c
